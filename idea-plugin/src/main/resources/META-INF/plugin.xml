<!-- Plugin Configuration File: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- Unique identifier of the plugin. It should be FQN, cannot be changed between the plugin versions. -->
    <!-- 插件的唯一标识符，应为完全限定名，版本间不可更改 -->
    <id>com.smarttestgen.idea-plugin</id>

    <!-- Public plugin name should be written in Title Case.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-name -->
    <!-- 插件名称应使用标题格式 -->
    <name>Test Case Generator</name>

    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <!-- 在插件页面显示的供应商名称 或组织ID -->
    <!-- 个体开发哈哈-->
    <vendor url="https://www.yourcompany.com">属于wwt个人</vendor>

    <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-description -->
    <description><![CDATA[
        <h2>测试用例生成器</h2>
        <p>这是一个智能测试用例生成插件，可以帮助开发者快速生成 JUnit 5 测试代码。</p>

        <h3>主要功能：</h3>
        <ul>
            <li><b>智能解析</b>：自动从自然语言描述中提取方法名、参数、返回类型、约束条件和期望</li>
            <li><b>结构化展示</b>：以清晰的格式展示解析结果，支持查看和编辑</li>
            <li><b>测试代码生成</b>：一键生成符合 JUnit 5 标准的测试代码</li>
            <li><b>约束条件支持</b>：支持参数约束条件（如最小值、最大值、长度限制等）</li>
            <li><b>代码结构分析</b>：自动分析项目代码结构，生成更准确的测试代码</li>
        </ul>

        <h3>使用方法：</h3>
        <ol>
            <li>在编辑器中选中方法需求描述文本</li>
            <li>右键点击，选择 <b>"Generate Test Code"</b></li>
            <li>查看结构化解析结果</li>
            <li>点击 <b>"Generate Test Code"</b> 按钮生成测试代码</li>
            <li>复制生成的测试代码到项目中使用</li>
        </ol>

        <h3>支持的语言：</h3>
        <p>中文和英文自然语言描述</p>
    ]]></description>

    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.platform</depends><!--可删除-->
    <depends>com.intellij.java</depends>

    <resource-bundle>messages.MyMessageBundle</resource-bundle>
    <!-- Extensions defined by the plugin.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij">
        <!-- ToolWindow configuration -->
        <!-- ToolWindow配置 -->
        <toolWindow id="TestGeneratorToolWindow"
                    secondary="false"
                    anchor="right"
                    canCloseContents="false"
                    doNotActivateOnStart="true"
                    factoryClass="com.smarttestgen.ideaplugin.toolwindow.TestGeneratorToolWindowFactory"
                    icon="AllIcons.Toolwindows.ToolWindowPalette"/>
    </extensions>
    <!--                    icon="AllIcons.Actions.Edit"-->

    <!-- Actions configuration -->
    <!-- Actions配置 -->
    <actions>
        <!-- 右键菜单配置 -->
        <!-- Right-click menu configuration -->
        <group id="MyEditorPopupMenu" text="Test Case Generator">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <action id="TestGeneratorToolWindowAction" class="com.smarttestgen.ideaplugin.TestGeneratorToolWindowAction"
                    text="Generate Test Code (Sidebar)" description="Generate test code in sidebar"/>
        </group>
    </actions>
</idea-plugin>